  "item": [
    {
      "id": "5a64375b-0f7d-4850-9677-57d877ef21ff",
      "name": "flow-meta",
      "description": {
        "content": "Operations for retrieving flow metadata",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "1b940453-a47d-484b-9d01-3022f546b823",
          "name": "Get flow metadata",
          "request": {
            "name": "Get flow metadata",
            "description": {
              "content": "Retrieves aggregated metadata for a flow, including:\n- Application or OU details based on type\n- Resolved design configuration (theme and layout)\n- i18n translations based on language and namespace filters\n- Registration flow enablement status\n\n**Note:** When `type=APP`, the OU metadata is only included in the response\nwhen the deployment has exactly one organization unit (i.e., `totalResults == 1`).\nFor deployments with multiple OUs, the OU metadata will be omitted from APP-type responses.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "flow",
                "meta"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "type",
                  "value": "<string>",
                  "description": "(Required) The type of entity to retrieve metadata for"
                },
                {
                  "disabled": false,
                  "key": "id",
                  "value": "<uuid>",
                  "description": "(Required) The UUID of the entity (application ID or organization unit ID)"
                },
                {
                  "disabled": true,
                  "key": "language",
                  "value": "<string>",
                  "description": "Language tag in BCP 47 format for i18n translations (e.g., `en`, `es`, `fr-CA`)"
                },
                {
                  "disabled": true,
                  "key": "namespace",
                  "value": "<string>",
                  "description": "Filter translations by namespace (e.g., `auth`, `errors`, `common`)"
                }
              ],
              "variable": [
                {
                  "description": {
                    "content": "",
                    "type": "text/plain"
                  },
                  "type": "any",
                  "value": "{{host}}",
                  "key": "host"
                },
                {
                  "description": {
                    "content": "",
                    "type": "text/plain"
                  },
                  "type": "any",
                  "value": "{{port}}",
                  "key": "port"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
